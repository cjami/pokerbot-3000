<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ app_name }}</title>
    <link rel="stylesheet" href="{{ request.url_for('static', path='styles.css') }}">
    <script type="module" src="{{ request.url_for('static', path='app.js') }}"></script>
  </head>
  <body class="min-h-screen bg-table text-ink antialiased">
    <main class="mx-auto flex min-h-screen w-full max-w-7xl flex-col gap-5 px-4 py-5 sm:px-6 lg:px-8">
      <header class="flex flex-wrap items-end justify-between gap-4 border-b border-neutral-300 pb-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-felt">Python orchestrator</p>
          <h1 class="mt-1 text-3xl font-black leading-tight sm:text-4xl">{{ app_name }}</h1>
        </div>
        <div class="control-bar" aria-label="Game controls">
          <button class="control-button control-button-primary" type="button" data-game-control="start">Start</button>
          <button class="control-button" type="button" data-game-control="stop">Stop</button>
        </div>
        <div class="grid grid-cols-2 gap-2 text-sm sm:grid-cols-4">
          <div class="metric">
            <span class="metric-label">Hand</span>
            <strong data-hand-id>{{ state.hand_id }}</strong>
          </div>
          <div class="metric">
            <span class="metric-label">Street</span>
            <strong data-street>{{ state.street }}</strong>
          </div>
          <div class="metric">
            <span class="metric-label">Pot</span>
            <strong data-pot>{{ state.pot }}</strong>
          </div>
          <div class="metric">
            <span class="metric-label">Waiting</span>
            <strong data-waiting>{{ state.waiting_for.type if state.waiting_for else "none" }}</strong>
          </div>
        </div>
      </header>

      <section class="grid gap-4 lg:grid-cols-[1.5fr_1fr]">
        <div class="panel">
          <div class="panel-heading">
            <h2>Table State</h2>
            <span data-api-status class="status-pill">API pending</span>
          </div>
          <div class="grid gap-3 md:grid-cols-3" data-seat-grid>
            {% for seat, player in players %}
              <article class="seat-panel{% if seat == state.active_player_seat %} seat-panel-active{% endif %}">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-sm font-semibold text-neutral-600">S{{ seat }}</p>
                    <h3 class="text-xl font-black">{{ player.name }}</h3>
                  </div>
                  {% if seat == state.dealer_seat %}
                    <span class="dealer-button">D</span>
                  {% endif %}
                </div>
                <dl class="mt-4 grid gap-2 text-sm">
                  <div class="row-stat">
                    <dt>Status</dt>
                    <dd>{{ player.status }}</dd>
                  </div>
                  <div class="row-stat">
                    <dt>Stack</dt>
                    <dd>{{ player.stack }}</dd>
                  </div>
                  <div class="row-stat">
                    <dt>Committed</dt>
                    <dd>{{ player.committed_this_street }}</dd>
                  </div>
                </dl>
              </article>
            {% endfor %}
          </div>
        </div>

        <aside class="panel">
          <div class="panel-heading">
            <h2>Board</h2>
            <span class="status-pill" data-board-source>{{ state.board_source }}</span>
          </div>
          <div class="card-row" data-board-row>
            {% if state.board %}
              {% for card in state.board %}
                <span class="playing-card">{{ card.label }}</span>
              {% endfor %}
            {% else %}
              <span class="empty-state">No board cards recognised</span>
            {% endif %}
          </div>
          <dl class="mt-4 grid gap-2 text-sm">
            <div class="row-stat">
              <dt>Engine</dt>
              <dd data-engine-status>{{ state.automation_status }}</dd>
            </div>
            <div class="row-stat">
              <dt>Active seat</dt>
              <dd data-active-seat>S{{ state.active_player_seat }}</dd>
            </div>
            <div class="row-stat">
              <dt>Paused for</dt>
              <dd data-waiting-reason>{{ state.waiting_for.reason if state.waiting_for else "none" }}</dd>
            </div>
            <div class="row-stat">
              <dt>To call</dt>
              <dd data-to-call>{{ state.current_bet_to_call }}</dd>
            </div>
            <div class="row-stat">
              <dt>Min raise</dt>
              <dd data-min-raise>{{ state.min_raise_to }}</dd>
            </div>
          </dl>
        </aside>
      </section>

      <section class="grid gap-4 lg:grid-cols-3">
        <div class="panel">
          <div class="panel-heading">
            <h2>Public Recognition</h2>
            <span class="status-pill" data-recognition-status>{{ state.board_recognition.status }}</span>
          </div>
          <form class="camera-controls" data-camera-form>
            <label>
              <span>Camera</span>
              <select data-camera-device>
                <option value="">Default camera</option>
              </select>
            </label>
            <button class="control-button" type="submit">Use</button>
          </form>
          <p class="camera-status" data-camera-status>Camera idle</p>
          <div class="camera-stage" data-camera-stage>
            <video
              class="camera-preview"
              data-public-camera-preview
              autoplay
              muted
              playsinline
              hidden
            ></video>
            <div class="zone-overlay" data-zone-overlay></div>
          </div>
          <form class="zone-controls" data-zone-form>
            <label>
              <span>Zone</span>
              <select data-zone-select>
                <option value="board">Board</option>
                <option value="seat_1">Seat 1</option>
                <option value="seat_2">Seat 2</option>
                <option value="seat_3">Seat 3</option>
              </select>
            </label>
            <button class="control-button" type="button" data-zone-clear>Clear</button>
          </form>
          <div class="card-row" data-detected-board>
            {% if state.board_recognition.latest_observation and state.board_recognition.latest_observation.board_cards %}
              {% for card in state.board_recognition.latest_observation.board_cards %}
                <span class="playing-card">{{ card.label }}</span>
              {% endfor %}
            {% else %}
              <span class="empty-state">No detection yet</span>
            {% endif %}
          </div>
          <dl class="mt-4 grid gap-2 text-sm">
            <div class="row-stat">
              <dt>Expected</dt>
              <dd data-recognition-expected>{{ state.board_recognition.expected_card_count or "none" }}</dd>
            </div>
            <div class="row-stat">
              <dt>Stable</dt>
              <dd data-recognition-stable>{{ state.board_recognition.stable_sample_count }}/{{ state.board_recognition.required_stable_samples }}</dd>
            </div>
            <div class="row-stat">
              <dt>Confidence</dt>
              <dd data-recognition-confidence>{{ "%.0f"|format((state.board_recognition.latest_observation.confidence if state.board_recognition.latest_observation else 0) * 100) }}%</dd>
            </div>
            <div class="row-stat">
              <dt>Issue</dt>
              <dd data-recognition-error>{{ state.board_recognition.last_error or "none" }}</dd>
            </div>
          </dl>
          <dl class="mt-4 grid gap-2 text-sm">
            <div class="row-stat">
              <dt>Showdown</dt>
              <dd data-showdown-status>{{ state.showdown.status }}</dd>
            </div>
            <div class="row-stat">
              <dt>Reveal</dt>
              <dd data-showdown-current>{{ "S%s"|format(state.showdown.current_reveal_seat) if state.showdown.current_reveal_seat else "none" }}</dd>
            </div>
            <div class="row-stat">
              <dt>Winner</dt>
              <dd data-showdown-winner>{{ state.showdown.winner_seats|join(", ") if state.showdown.winner_seats else "none" }}</dd>
            </div>
          </dl>
        </div>

        <div class="panel">
          <div class="panel-heading">
            <h2>Private Recognition</h2>
          </div>
          <div class="space-y-3" data-private-recognition>
            {% for private_state in private_states %}
              <div class="status-row">
                <div>
                  <p class="font-bold">{{ private_state.agent_id|title }}</p>
                  <p class="text-sm text-neutral-600">S{{ private_state.seat }} - {{ private_state.hole_cards|length }}/2 cards</p>
                </div>
                <span class="status-pill">{{ "%.0f"|format(private_state.confidence * 100) }}%</span>
              </div>
            {% endfor %}
          </div>
        </div>

        <div class="panel">
          <div class="panel-heading">
            <h2>Clients</h2>
          </div>
          <div class="space-y-3" data-clients>
            {% for client in client_statuses %}
              <div class="status-row">
                <div>
                  <p class="font-bold">{{ client.client_id|replace("_", " ")|title }}</p>
                  <p class="text-sm text-neutral-600">{{ client.status }}</p>
                </div>
                <span class="status-pill">{{ client.connection }}</span>
              </div>
            {% endfor %}
          </div>
        </div>

        <div class="panel">
          <div class="panel-heading">
            <h2>Legal Actions</h2>
          </div>
          <div class="flex flex-wrap gap-2" data-legal-actions>
            {% for action in state.legal_actions %}
              <span class="action-chip">{{ action }}</span>
            {% endfor %}
          </div>
          <div class="mt-4 border-t border-neutral-200 pt-4">
            <p class="text-sm font-bold text-neutral-700">Known gaps</p>
            <ul class="mt-2 space-y-1 text-sm text-neutral-600" data-uncertainties>
              {% for uncertainty in state.uncertainties %}
                <li>{{ uncertainty }}</li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </section>

      <section class="panel flex-1">
        <div class="panel-heading">
          <h2>Event Log</h2>
          <span class="status-pill">{{ events|length }} shown</span>
        </div>
        <ol class="event-list" data-event-list>
          {% for event in events|reverse %}
            <li>
              <span>{{ event.event_type }}</span>
              <strong>{{ event.summary }}</strong>
              <time>{{ event.created_at.strftime("%H:%M:%S") }}</time>
            </li>
          {% endfor %}
        </ol>
      </section>
    </main>
  </body>
</html>
